# Backend service config. Copy to server/.env and fill in. Never commit secrets.
PORT=4000

# Supabase (worldcup project)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx        # read path (RLS allows public SELECT)
SUPABASE_SERVICE_ROLE_KEY=                  # REQUIRED for ingestion writes (dashboard → API → service_role)

# AI analyst (Google Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ingestion
INGEST_ENABLED=true
INGEST_INTERVAL_SEC=60
SPORTS_API_KEY=                             # optional API-Football key (deep lineups/players)
SPORTS_API_PROVIDER=api-football
