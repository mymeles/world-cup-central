# --- AI (Google Gemini) ---
# Put your Gemini API key in a local .env file. Do not commit the real key.
# The server route also accepts GEMINI_API_KEY as an alias, but the AI SDK's
# standard variable is GOOGLE_GENERATIVE_AI_API_KEY.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: override the Gemini model.
GEMINI_MODEL=gemini-2.5-flash

# --- Native builds only ---
# Point native (iOS/Android) builds at your deployed API origin in production.
# Leave empty for web and Expo dev (auto-detected).
EXPO_PUBLIC_API_URL=

# --- Live data providers ---
# ESPN's public World Cup scoreboard is used as a no-key fallback for fixtures
# and scores. Add API-Football when you need a stronger paid/keyed provider.
# See docs/DATA_SOURCES.md. These stay server-side; do not prefix with EXPO_PUBLIC.
SPORTS_API_KEY=
SPORTS_API_PROVIDER=api-football
SPORTS_API_FOOTBALL_LEAGUE=1
SPORTS_API_FOOTBALL_SEASON=2026
